{
    "name": "hazina-asili/natural-compounds-db",
    "description": "Natural Organic Compounds Database Management System",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "helpers/functions.php"
        ]
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
