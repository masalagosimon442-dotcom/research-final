# Application
APP_NAME="HAZINA ASILI"
APP_FULL_NAME="Mfumo wa Hifadhidata ya Misombo ya Asili ya Kikaboni"
APP_VERSION=3.0.0
APP_URL=http://localhost/DB/project/
APP_ENV=development
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=natural_compounds_db
DB_CHARSET=utf8mb4

# Session
SESSION_LIFETIME=3600
RECORDS_PER_PAGE=15

# Security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
FORCE_HTTPS=false
ADMIN_PASSWORD=ChangeThisToYourSecretPassword

# Email (SMTP)
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@hazina-asili.com
MAIL_FROM_NAME="HAZINA ASILI"

# AI Assistant (OpenAI-compatible API)
AI_ENABLED=false
AI_API_KEY=your-openai-api-key-here
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo

# OAuth (Google) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/DB/project/controllers/oauth.php?provider=google&action=callback

# OAuth (Microsoft) — https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost/DB/project/controllers/oauth.php?provider=microsoft&action=callback

# File Uploads
MAX_FILE_SIZE=5242880
UPLOAD_DIR=assets/uploads/
